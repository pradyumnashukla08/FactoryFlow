# ============================================
# FactoryFlow Server — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit the real .env file to version control.

# Server
PORT=5001
NODE_ENV=development

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=factoryflow
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Authentication
JWT_SECRET=replace_with_a_64_char_random_string
JWT_EXPIRES_IN=7d

# Email / SMTP (for payment reminders)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=FactoryFlow <you@gmail.com>

# Reminder Cron Schedule (default: daily at 9 AM IST)
REMINDER_CRON=0 9 * * *

# CORS — allowed frontend origin(s) in production (comma-separated)
CORS_ORIGIN=https://yourdomain.com

# Logging level: error | warn | info | http | debug
LOG_LEVEL=info
